<%- include('partials/header') %>
    <main>
        <div class="categories-container">
            <h1>Categories</h1>
            <div class="categories-list">
                <% categories.forEach(category => { %>
                    <div class="category-item">
                        <h2><%= category.name %></h2>
                        <p><%= category.description %></p>
                    </div>
                <% }); %>
            </div>
        </div>
    </main>
    <%- include('partials/footer') %>